<Window x:Class="Ambii.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:Ambii.Views" 
        Title="Ambii Photobooth" 
        WindowState="Maximized" 
        WindowStyle="None"
        KeyDown="Window_KeyDown" 
        Focusable="True"
        Background="Black">

    <Grid>
        <md:Transitioner x:Name="MainTransitioner" 
                         SelectedIndex="0" 
                         AutoApplyTransitionOrigins="True">


            <md:Transitioner.InputBindings>
                <KeyBinding Key="Left" Command="{x:Static md:Transitioner.MovePreviousCommand}" />
                <KeyBinding Key="Right" Command="{x:Static md:Transitioner.MoveNextCommand}" />
            </md:Transitioner.InputBindings>

            <md:TransitionerSlide Background="Black">
                <views:StartView />
            </md:TransitionerSlide>

            <md:TransitionerSlide ClipToBounds="True" Background="Black">

                <md:TransitionerSlide.ForwardWipe>
                    <md:CircleWipe />
                </md:TransitionerSlide.ForwardWipe>

                <md:TransitionerSlide.BackwardWipe>
                    <md:SlideWipe Direction="Right" />
                </md:TransitionerSlide.BackwardWipe>

                <md:TransitionerSlide.OpeningEffects>
                    <md:TransitionEffect Kind="FadeIn" Duration="0:0:0.3" />

                    <md:TransitionEffect Kind="ExpandIn" Duration="0:0:0.3" />
                </md:TransitionerSlide.OpeningEffects>

                <views:FrameSelectionView />
            </md:TransitionerSlide>

        </md:Transitioner>
        <StackPanel x:Name="InactivityPanel" 
                    Panel.ZIndex="100"
                    VerticalAlignment="Top" 
                    HorizontalAlignment="Right" 
                    Margin="40"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">

            <TextBlock Text="THỜI GIAN CÒN LẠI" 
                       Foreground="White" FontSize="12" FontWeight="Bold" Opacity="0.7" 
                       HorizontalAlignment="Right"/>

            <TextBlock x:Name="TxtCountdown" 
                       Text="60s" 
                       Foreground="#FF69B4" 
                       FontSize="36" FontWeight="ExtraBold" 
                       HorizontalAlignment="Right">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>