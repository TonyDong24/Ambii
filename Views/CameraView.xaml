<UserControl x:Class="Ambii.Views.CameraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             Background="Black">

    <Grid x:Name="RootCameraGrid">
        <Viewbox Stretch="Uniform" Margin="30">
            <Grid x:Name="CameraArea">
                <Image x:Name="ImgLivePreview" Stretch="UniformToFill" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" />

                <Image x:Name="ImgFrameOverlay" IsHitTestVisible="False" Stretch="Fill" />

                <Border x:Name="FlashOverlay" Background="White" Opacity="0" IsHitTestVisible="False"/>
            </Grid>
        </Viewbox>

        <Grid IsHitTestVisible="False">
            <TextBlock x:Name="txtCountdown" 
                       Text="3" Foreground="White" FontSize="150" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock x:Name="txtStatus" Text="SMILE!" Foreground="#FF00FF00" FontSize="60"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,50"
                       Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>