<UserControl x:Class="Ambii.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Black">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="AMBII" 
           FontSize="200" FontWeight="Black" FontStyle="Italic" Foreground="White" 
           HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect x:Name="TextGlow" BlurRadius="20" Color="LightGray" Opacity="0.7" ShadowDepth="0"/>
                </TextBlock.Effect>
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="TextBlock.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="TextGlow" 
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="2" To="40" Duration="0:0:1.5" 
                                     AutoReverse="True" RepeatBehavior="Forever" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>
            

            <TextBlock Text="Keep story in your pocket" 
                       FontSize="30" 
                       FontWeight="Bold"
                       FontStyle="Italic"
                       Foreground="#444444" 
                       HorizontalAlignment="Center" 
                       Margin="500,0,0,100"/>
            <Button x:Name="BtnStart" 
                    Click="BtnStart_Click"
                    Width="280" Height="80" 
                    Background="White" Foreground="Black" 
                    BorderBrush="White" Cursor="Hand"
                    RenderTransformOrigin="0.5,0.5"
                    materialDesign:ButtonAssist.CornerRadius="40">

                <Button.Effect>
                    <DropShadowEffect Color="LightGray" 
                          BlurRadius="15" 
                          ShadowDepth="0" 
                          Opacity="0.8"/>
                </Button.Effect>

                <Button.RenderTransform>
                    <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1" />
                </Button.RenderTransform>

                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="40"/>
                    </Style>
                </Button.Resources>

                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ButtonScale" 
                                     Storyboard.TargetProperty="ScaleX"
                                     From="1.0" To="1.1" Duration="0:0:0.8" 
                                     AutoReverse="True" RepeatBehavior="Forever" />
                                <DoubleAnimation Storyboard.TargetName="ButtonScale" 
                                     Storyboard.TargetProperty="ScaleY"
                                     From="1.0" To="1.1" Duration="0:0:0.8" 
                                     AutoReverse="True" RepeatBehavior="Forever" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>

                <TextBlock Text="START" FontSize="32" FontWeight="Black"/>
            </Button>
        </StackPanel>
        <Button x:Name="BtnAdminSetting"
                        VerticalAlignment="Top" 
                        HorizontalAlignment="Right"
                        Margin="30"
                        Background="Transparent" 
                        BorderBrush="Transparent"
                        Click="BtnAdminSetting_Click"
        
                        materialDesign:RippleAssist.IsDisabled="True"
                        Padding="0"
                        Style="{StaticResource MaterialDesignFlatButton}">

    <materialDesign:PackIcon Kind="Cog" 
                             Width="35" 
                             Height="35" 
                             Foreground="LightGray"/>
</Button>
    </Grid>
</UserControl>