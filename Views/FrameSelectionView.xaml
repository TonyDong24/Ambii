<Window x:Class="Ambii.Views.FrameSelectionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Select Your Frame" WindowState="Maximized" 
        WindowStyle="None" Background="#121212" Foreground="White">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Pick Up Your Frame"
                       Foreground="WhiteSmoke"
                       FontFamily="pack://application:,,,/Assets/Fonts/#Rouge Script"
                       FontSize="150" FontWeight="Heavy" 
                       HorizontalAlignment="Center" Margin="0,50,0,50">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="5" Color="LightGray" ShadowDepth="0"/>
                </TextBlock.Effect>

            </TextBlock>
            <Button x:Name="BtnBack" 
                    Content="BACK" Width="150" 
                    Style="{StaticResource MaterialDesignOutlinedButton}" 
                    BorderBrush="Gray" Foreground="Gray" Click="BtnBack_Click"/>

            <StackPanel Orientation="Horizontal">

                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                        Width="300" Height="450" Margin="20" Click="FrameSelected_Click" Tag="ClassicStrip">
                    <Border Background="#1A1A1A" CornerRadius="15" BorderThickness="2" BorderBrush="#25F4EE">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="ViewColumn" Width="180" Height="380" HorizontalAlignment="Center" Foreground="#25F4EE"/>
                            <TextBlock Text="CLASSIC STRIP" FontWeight="Bold" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                            <TextBlock Text="3 Photos - 2x6 inch" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                        Width="300" Height="450" Margin="20" Click="FrameSelected_Click" Tag="Grid4">
                    <Border Background="#1A1A1A" CornerRadius="15" BorderThickness="2" BorderBrush="#FE2C55">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="ViewGrid" Width="180" Height="380" HorizontalAlignment="Center" Foreground="#FE2C55"/>
                            <TextBlock Text="GRID 4" FontWeight="Bold" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                            <TextBlock Text="4 Photos - 4x6 inch" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                        Width="300" Height="450" Margin="20" Click="FrameSelected_Click" Tag="Single">
                    <Border Background="#1A1A1A" CornerRadius="15" BorderThickness="2" BorderBrush="#9B30FF">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="ImageOutline" Width="180" Height="380" HorizontalAlignment="Center" Foreground="#9B30FF"/>
                            <TextBlock Text="SINGLE SHOT" FontWeight="Bold" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                            <TextBlock Text="1 Photo - Large Size" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

            </StackPanel>
            <Button x:Name="BtnNext"
                    Opacity="0.2"
                    Click="BtnNext_Click"
                    Width="280" Height="80" 
                    Background="White" Foreground="Black" 
                    Cursor="Hand"
                    VerticalAlignment="Bottom" Margin="0,0,0,50"
                    materialDesign:ButtonAssist.CornerRadius="40">

                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="LET'S GO" FontSize="28" FontWeight="Black" VerticalAlignment="Center"/>
                        <materialDesign:PackIcon Kind="ArrowRightBold" Width="30" Height="30" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>

                <Button.BorderBrush>
                    <LinearGradientBrush x:Name="NextBorderGradient" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="Cyan" Offset="0.0" />
                        <GradientStop Color="Transparent" Offset="0.25" />
                        <GradientStop Color="DeepPink" Offset="0.5" />
                        <GradientStop Color="Transparent" Offset="0.75" />
                        <GradientStop Color="Cyan" Offset="1.0" />

                        <LinearGradientBrush.RelativeTransform>
                            <RotateTransform x:Name="NextBorderRotate" CenterX="0.5" CenterY="0.5" Angle="0" />
                        </LinearGradientBrush.RelativeTransform>
                    </LinearGradientBrush>
                </Button.BorderBrush>

                <Button.BorderThickness>4</Button.BorderThickness>

                <Button.Effect>
                    <DropShadowEffect x:Name="NextNeonGlow" Color="Cyan" 
                          BlurRadius="30" 
                          ShadowDepth="0" 
                          Opacity="0.8"/>
                </Button.Effect>

                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="NextBorderRotate"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:2"
                                     RepeatBehavior="Forever" />

                                <ColorAnimationUsingKeyFrames Storyboard.TargetName="NextNeonGlow"
                                                   Storyboard.TargetProperty="Color"
                                                   Duration="0:0:4" RepeatBehavior="Forever">
                                    <LinearColorKeyFrame Value="Cyan" KeyTime="0:0:0" />
                                    <LinearColorKeyFrame Value="DeepPink" KeyTime="0:0:2" />
                                    <LinearColorKeyFrame Value="Cyan" KeyTime="0:0:4" />
                                </ColorAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>
        </StackPanel>
    </Grid>
</Window>