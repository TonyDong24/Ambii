<UserControl x:Class="Ambii.Views.FrameSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920"
             Background="#121212" Foreground="White">


    <Grid>
        <Grid>

            <Image Stretch="UniformToFill"
       RenderOptions.BitmapScalingMode="LowQuality">
                <Image.Source>
                    <BitmapImage UriSource="pack://application:,,,/Assets/pinky_background.png" 
                     DecodePixelWidth="1920" 
                     CacheOption="OnLoad"/>
                </Image.Source>
            </Image>


        </Grid>


        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <!-- Back -->
                <RowDefinition Height="6*"/>
                <!-- Cards -->
                <RowDefinition Height="1.5*"/>
                <!-- Next -->
            </Grid.RowDefinitions>



            <Button x:Name="BtnBack" Grid.Row="0"
                Content="BACK" Width="120" Height="35"
                Style="{StaticResource MaterialDesignOutlinedButton}" 
                BorderBrush="Gray" Foreground="Gray" 
                Margin="0,0,0,0"
                Click="BtnBack_Click"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="533" Margin="0,35,0,0" Grid.Row="1">
                <StackPanel.Resources>

                    <Style x:Key="FrameCardStyle" TargetType="Button">
                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                        <Setter Property="Opacity" Value="0.4"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Setter.Value>
                        </Setter>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" 
                                            Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="0" 
                                            CornerRadius="30">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#15FADADD"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>

                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="Panel.ZIndex" Value="99"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Resources>

                <Button Style="{StaticResource FrameCardStyle}"
                        Width="294"
                        Height="544"
                        Margin="20,0"
                        VerticalAlignment="Center"
                        Click="FrameSelected_Click"
                        Tag="ClassicStrip">

                    <Border CornerRadius="30"
                            BorderThickness="1.5"
                            BorderBrush="#B05B67"
                            Background="#FFFFFF"
                            Width="200"
                            Height="517">

                        <Border.Effect>
                            <DropShadowEffect x:Name="GlowClassic"
                                              Color="#FFB7C5"
                                              BlurRadius="5"
                                              ShadowDepth="0"
                                              Opacity="0.2"/>
                        </Border.Effect>

                        <StackPanel VerticalAlignment="Center">

                            <StackPanel Margin="0,0,0,1">
                                <Border Width="140" Height="90" Background="#FADADD" BorderBrush="#E5989B" BorderThickness="1" CornerRadius="4" Margin="0,4"/>
                                <Border Width="140" Height="90" Background="#FADADD" BorderBrush="#E5989B" BorderThickness="1" CornerRadius="4" Margin="0,4"/>
                                <Border Width="140" Height="90" Background="#FADADD" BorderBrush="#E5989B" BorderThickness="1" CornerRadius="4" Margin="0,4"/>
                                <Border Width="140" Height="90" Background="#FADADD" BorderBrush="#E5989B" BorderThickness="1" CornerRadius="4" Margin="0,4"/>
                            </StackPanel>
                            <TextBlock Text="CLASSIC STRIP"
                                        Foreground="#B05B67"
                                        FontSize="16"
                                        FontWeight="Black"
                                        FontStyle="Italic"
                                        HorizontalAlignment="Center"/>

                            <StackPanel Margin="0,0,0,0" Orientation="Horizontal" HorizontalAlignment="Center">

                                <TextBlock Text="4 PHOTOS • 2X6 INCH"
                                           Foreground="#666666"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,8"/>

                                <materialDesign:PackIcon x:Name="IconClassic"
                                                         Kind="CheckCircle"
                                                         Foreground="#B05B67"
                                                         Width="22"
                                                         Height="22"
                                                         Margin="5,0,0,0"
                                                         HorizontalAlignment="Center"/>


                            </StackPanel>

                        </StackPanel>

                    </Border>

                    <Button.Triggers>

                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="GlowClassic"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="GlowClassic"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="35"
                                                     Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="GlowClassic"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0.2"
                                     Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="GlowClassic"
                                     Storyboard.TargetProperty="BlurRadius"
                                     To="5"
                                     Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                    </Button.Triggers>

                </Button>

                <Button Style="{StaticResource FrameCardStyle}" Width="554" Height="453" Margin="20,0"
                        Click="FrameSelected_Click" Tag="Postcard4x6">
                    <Border CornerRadius="25" BorderThickness="2" BorderBrush="#E5989B" Background="#FDF0F0" Width="452" Height="369">
                        <Border.Effect>
                            <DropShadowEffect x:Name="GlowPostcard" Color="#FFB7C5" BlurRadius="1" ShadowDepth="0" Opacity="0.2"/>
                        </Border.Effect>


                        <StackPanel VerticalAlignment="Center" Height="369">
                            <Border Width="452" Height="279" Background="#E5989B" CornerRadius="25" Margin="0,0,0,15" BorderBrush="Transparent" BorderThickness="0" HorizontalAlignment="Center">
                                <UniformGrid Columns="2" Rows="2" Margin="10,10,10,10">
                                    <Border Background="#FADADD" CornerRadius="4" Margin="3" BorderBrush="#E5989B" BorderThickness="1" />
                                    <Border Background="#FADADD" CornerRadius="4" Margin="3" BorderBrush="#E5989B" BorderThickness="1" />
                                    <Border Background="#FADADD" CornerRadius="4" Margin="3" BorderBrush="#E5989B" BorderThickness="1" />
                                    <Border Background="#FADADD" CornerRadius="4" Margin="3" BorderBrush="#E5989B" BorderThickness="1" />
                                </UniformGrid>
                            </Border>

                            <TextBlock Text="NOIR POSTCARD" FontWeight="Black" FontSize="26" FontStyle="Italic" Foreground="#FE2C55" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                                <TextBlock Text="4 PHOTOS • 4X6 INCH" Foreground="#666" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                <materialDesign:PackIcon x:Name="IconPostcard" Kind="CheckCircle" Foreground="#FE2C55" Width="20" Height="20" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                    </Border>

                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.GotFocus">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="GlowPostcard" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                                    <DoubleAnimation Storyboard.TargetName="GlowPostcard" Storyboard.TargetProperty="BlurRadius" To="35" Duration="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.LostFocus">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="GlowPostcard" Storyboard.TargetProperty="Opacity" To="0.2" Duration="0:0:0.3"/>
                                    <DoubleAnimation Storyboard.TargetName="GlowPostcard" Storyboard.TargetProperty="BlurRadius" To="30" Duration="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <Button Style="{StaticResource FrameCardStyle}" Width="350" Height="500" Margin="20,0"
                        Click="FrameSelected_Click" Tag="Single">
                    <Border CornerRadius="25" BorderThickness="1.5" BorderBrush="#CBAACB" Background="#FFFFFF">
                        <Border.Effect>
                            <DropShadowEffect x:Name="GlowSolo" Color="#D8BFD8" BlurRadius="30" ShadowDepth="0" Opacity="0.2"/>
                        </Border.Effect>
                        <StackPanel VerticalAlignment="Center">
                            <Border Width="220" Height="200" Background="#A678B3" CornerRadius="25" Margin="0,0,0,25">
                                <Border Width="75" Height="100" Background="#D8BFD8" BorderBrush="#333" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="SPECIAL FRAME" FontWeight="Black" FontSize="24" FontStyle="Italic" Foreground="#A678B3" HorizontalAlignment="Center"/>
                            <TextBlock Text="1 PHOTO • 5X7 INCH" Foreground="#444" FontSize="12" FontWeight="Bold" Margin="0,8,0,20" HorizontalAlignment="Center"/>
                            <materialDesign:PackIcon x:Name="IconSolo" Kind="CheckCircle" Foreground="#9B30FF" Width="25" Height="25" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.GotFocus">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="GlowSolo" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                                    <DoubleAnimation Storyboard.TargetName="GlowSolo" Storyboard.TargetProperty="BlurRadius" To="35" Duration="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.LostFocus">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="GlowSolo" Storyboard.TargetProperty="Opacity" To="0.2" Duration="0:0:0.3"/>
                                    <DoubleAnimation Storyboard.TargetName="GlowSolo" Storyboard.TargetProperty="BlurRadius" To="30" Duration="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>
            </StackPanel>

            <Button x:Name="BtnNext"
                    Grid.Row="2"
                    Click="BtnNext_Click"
                    Opacity="0.2"
                    Width="280" Height="80"                    
                    Background="White"
                    Foreground="Black"
                    Cursor="Hand"
                    HorizontalAlignment="Center" VerticalAlignment="Center"                    
                    Margin="0,20"
                    materialDesign:ButtonAssist.CornerRadius="40">

                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="LET'S GO" FontSize="28" FontWeight="Black" VerticalAlignment="Center"/>
                        <materialDesign:PackIcon Kind="ArrowRightBold" Width="30" Height="30" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button.Content>

                <Button.BorderBrush>
                    <LinearGradientBrush x:Name="NextBorderGradient" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="Cyan" Offset="0.0" />
                        <GradientStop Color="Transparent" Offset="0.25" />
                        <GradientStop Color="DeepPink" Offset="0.5" />
                        <GradientStop Color="Transparent" Offset="0.75" />
                        <GradientStop Color="Cyan" Offset="1.0" />
                        <LinearGradientBrush.RelativeTransform>
                            <RotateTransform x:Name="NextBorderRotate" CenterX="0.5" CenterY="0.5" Angle="0" />
                        </LinearGradientBrush.RelativeTransform>
                    </LinearGradientBrush>
                </Button.BorderBrush>

                <Button.BorderThickness>4</Button.BorderThickness>

                <Button.Effect>
                    <DropShadowEffect x:Name="NextNeonGlow" Color="Cyan" 
                          BlurRadius="30" 
                          ShadowDepth="0" 
                          Opacity="0.8"/>
                </Button.Effect>

                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="NextBorderRotate"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:2"
                                     RepeatBehavior="Forever" />

                                <ColorAnimationUsingKeyFrames Storyboard.TargetName="NextNeonGlow"
                                                   Storyboard.TargetProperty="Color"
                                                   Duration="0:0:4" RepeatBehavior="Forever">
                                    <LinearColorKeyFrame Value="Cyan" KeyTime="0:0:0" />
                                    <LinearColorKeyFrame Value="DeepPink" KeyTime="0:0:2" />
                                    <LinearColorKeyFrame Value="Cyan" KeyTime="0:0:4" />
                                </ColorAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>
        </Grid>
    </Grid>
</UserControl>