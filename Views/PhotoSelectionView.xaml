<UserControl x:Class="Ambii.Views.PhotoSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#121212">
    
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="15" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="CHỌN ẢNH" Foreground="White" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,20"/>

                <ListBox x:Name="ListCapturedPhotos" 
                 Background="Transparent" 
                 BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                 HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,15" Cursor="Hand" MouseLeftButtonDown="Photo_Click">
                                <Border x:Name="PhotoBorder" CornerRadius="8" ClipToBounds="True" 
                                BorderBrush="{Binding BorderColor}" BorderThickness="4">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" Height="150"/>

                                        <Border Background="#CCF4747E" Width="40" Height="40" 
                                        HorizontalAlignment="Right" VerticalAlignment="Top" 
                                        CornerRadius="0,0,0,10"
                                        Visibility="{Binding IsSelectedVisibility}">
                                            <TextBlock Text="{Binding SelectionOrder}" Foreground="White" 
                                               FontWeight="Bold" VerticalAlignment="Center" 
                                               HorizontalAlignment="Center" FontSize="18"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="40,0" x:Name="PreviewContainer">
            <Viewbox Stretch="Uniform">
                <Grid Width="{Binding CurrentDisplayWidth}" Height="{Binding CurrentDisplayHeight}">

                    <ItemsControl ItemsSource="{Binding PreviewSlots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Background="Transparent"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding ImageSource}" 
                               Stretch="UniformToFill"
                               Width="{Binding Config.Width}" 
                               Height="{Binding Config.Height}">
                                    <Image.RenderTransform>
                                        <TranslateTransform X="{Binding Config.X}" Y="{Binding Config.Y}"/>
                                    </Image.RenderTransform>
                                </Image>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Image x:Name="MainFrameImage" 
                       Source="{Binding SelectedFramePath}" 
                       Stretch="Fill"
                       Panel.ZIndex="10"
                       IsHitTestVisible="False"/>
                </Grid>
            </Viewbox>
        </Grid>
        <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="15" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="CHỌN KHUNG" Foreground="White" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,20"/>

                <ListBox x:Name="ListFrames" 
                         Background="Transparent" 
                         BorderThickness="0"
                         ItemsSource="{Binding AllFrames}"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         SelectionMode="Single"
                         SelectionChanged="ListFrames_SelectionChanged">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent" Margin="0,0,0,15" Cursor="Hand" MouseLeftButtonDown="Frame_Click">
                                <Border CornerRadius="8" ClipToBounds="True" Background="#2D2D2D">
                                    <StackPanel IsHitTestVisible="False">
                                        <Image Source="{Binding FramePath}" Height="180" Stretch="Uniform" Margin="5"/>
                                        <TextBlock Text="{Binding Name}" Foreground="White" HorizontalAlignment="Center" Margin="5"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>