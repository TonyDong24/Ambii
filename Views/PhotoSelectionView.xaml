<UserControl x:Class="Ambii.Views.PhotoSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#121212">
    
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="15" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="CHỌN ẢNH" Foreground="White" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,20"/>

                <ListBox x:Name="ListCapturedPhotos" 
                 Background="Transparent" 
                 BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                 HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,15" Cursor="Hand" MouseLeftButtonDown="Photo_Click">
                                <Border x:Name="PhotoBorder" CornerRadius="8" ClipToBounds="True" 
                                BorderBrush="{Binding BorderColor}" BorderThickness="4">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" Height="150"/>

                                        <Border Background="#CCF4747E" Width="40" Height="40" 
                                        HorizontalAlignment="Right" VerticalAlignment="Top" 
                                        CornerRadius="0,0,0,10"
                                        Visibility="{Binding IsSelectedVisibility}">
                                            <TextBlock Text="{Binding SelectionOrder}" Foreground="White" 
                                               FontWeight="Bold" VerticalAlignment="Center" 
                                               HorizontalAlignment="Center" FontSize="18"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="40,0" x:Name="PreviewContainer">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

                <Viewbox Stretch="Uniform" 
                 Width="{Binding ElementName=MainFrameImage, Path=ActualWidth}"
                 Height="{Binding ElementName=MainFrameImage, Path=ActualHeight}">
                    <ItemsControl ItemsSource="{Binding PreviewSlots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="1200" Height="1800" Background="Transparent"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding ImageSource}" 
                               Stretch="UniformToFill"
                               Width="{Binding Config.Width}" 
                               Height="{Binding Config.Height}">
                                    <Image.RenderTransform>
                                        <TranslateTransform X="{Binding Config.X}" Y="{Binding Config.Y}"/>
                                    </Image.RenderTransform>
                                </Image>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Viewbox>

                <Image x:Name="MainFrameImage" 
               Source="{Binding SelectedFramePath}" 
               Stretch="Uniform"
               IsHitTestVisible="False"/>

            </Grid>
        </Grid>
        <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="15" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="CHỌN KHUNG" Foreground="White" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,20"/>

                <ListBox x:Name="ListFrames" Background="Transparent" BorderThickness="0"
                 ItemsSource="{Binding AllFrames}"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                 SelectionChanged="ListFrames_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,15" CornerRadius="8" ClipToBounds="True" Background="#2D2D2D" Cursor="Hand">
                                <StackPanel>
                                    <Image Source="{Binding FramePath}" Height="180" Stretch="Uniform" Margin="5"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White" HorizontalAlignment="Center" Margin="5"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>